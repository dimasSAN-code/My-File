        <input type="text" name="b" placeholder="Nilai B"
        value="<?php if(isset($_POST['b'])) echo $_POST['b']; ?>">

        <br>
        <button type="submit" name="hitung">Hitung FPB</button>
    </form>

<?php
if(isset($_POST['hitung'])){

    $a = $_POST['a'];
    $b = $_POST['b'];

    if($a !== "" && $b !== ""){

        function fpb($x, $y){
            while($y != 0){
                $sisa = $x % $y;
                $x = $y;
                $y = $sisa;
            }
            return $x;
        }

        $hasil = fpb($a,$b);

        echo "<div class='hasil'>";
        echo "Hasil FPB: $hasil <br>";

        if($hasil == 1){
            echo "Kedua angka RELATIF PRIMA";
        }else{
            echo "Kedua angka TIDAK RELATIF PRIMA";
        }

        echo "</div>";
    }
}
?>

</div>

